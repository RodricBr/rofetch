#!/usr/bin/env bash


# Making sure default language is correct
export LANG=C.UTF-8

# Color variables
BANNER_COLOR="\033[0;31m" # Default light red to match banner color
SECONDARY_COLOR="\033[1;31m" # same ^^^^
ERROR_="\033[0;31m"
VERDE="\033[1;32m"
ROXO="\033[1;95m"
FIM="\033[0;00m"

# Checking for tmp marker file existence and .config color option file:
CONFIG_COLOR_FILE="$HOME/.config/rofetch-color-config"
MARKER_FILE="/tmp/.rofetch-first-execution"

# Checking if dependencies are installed in the first execution
function CHECK_DEP {
  local DEPEN_="ip ping free uname awk grep cut tr ps curl jq"

  printf "${ROXO}+ First execution, checking for ${FIM}${VERDE}Rofetch${ROXO} dependencies...${FIM}\n"
  for CMD_ in DEPEN_; do
    if command -v "$CMD_" >/dev/null 2>&1; then
      printf "${ERROR_}[Error]:${FIM} Missing dependency: $CMD_\n"
      exit 2
    fi
  done
  # Creating marker file after first execution
  touch "$MARKER_FILE"
}

# Checks for marker_file's existence, if it doesn't exist,
# creates it. (%/* shell native dirname alternative, instead of spawning new subshell)
[[ -f $MARKER_FILE ]] || {
  CHECK_DEP
  mkdir -p "${MARKER_FILE%/*}"
  : > "$MARKER_FILE"
}

# Checking for debug option flag:
if [[ "${@: -1}" == "-d" ]] || [[ "${@: -1}" == "--debug" ]]; then
  DEBUG_=true
  set -x
else
  DEBUG_=false
fi

# Help message (-h/--help)
function HELP_ {
  echo -e "
Usage: ${0##*/} [OPTION] [-d]

OPTIONS:
  -h | --help                     :: Shows this help message.
  -v | --version                  :: Shows current program version with changelog.
  -b | --banner /path/to/file     :: Set custom ASCII art banner. Must be no more than 15 lines.
  -d | --debug                    :: Runs the program with bash's debug mode.
                                     Debug flag MUST be the last argument!
                                     Example: ./rofetch -b ascii.txt -d
  CUSTOMIZATION OPTIONS:
  -bc  | --banner-color \"...\"     :: Temporaly changes banner color to a set of colors in a list. Use -bc \"x\" to see list of colors
  -sbc | --set-banner-color \"...\" :: Permanently changes banner color and storages in $HOME/.config/rofetch-color-config

  -sc  | --secondary-color \"...\"  :: Temporaly changes secondary color to a set of colors in a list. Use -bc \"x\" to see list of colors
  -ssc | --set-string-color \"...\" :: Permanently changes secondary color and storages in $HOME/.config/rofetch-color-config
  --reset-default                 :: Resets banner and secondary color to default (light red).

DESCRIPTION:
Rofetch is a command line interface system information tool inspired by neofetch
written fully in bash script. Its main purpose is to be fast, reliable and clean.
Rofetch displays information next to a default \"R\" ASCII art but the art can also
be modified by a file containing your ASCII art of choice using the \"-b/--banner\" option.
The file needs to have no more than 15 lines otherwise it'll be cut off.


Improvements ideas and bug reports are welcome and can be solicited at:
https://github.com/RodricBr/rofetch/issues
"
  exit 0
}

# Version message and changelog (-v/--version)
