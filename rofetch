# Creating .config color file if non existant and checking if there's set color
if [[ -f "$CONFIG_COLOR_FILE" ]]; then
  while IFS= read -r line; do
    case "$line" in
      "[banner-color]"*" "*)
        SAVED_BANNER_COLOR="${line#* }"
        ;;
      "[secondary-color]"*" "*)
        SAVED_SECONDARY_COLOR="${line#* }"
        ;;
    esac
  done < "$CONFIG_COLOR_FILE"

  [[ -n "$SAVED_BANNER_COLOR" ]] \
    && BANNER_COLOR="${STRING_COLORS[$SAVED_BANNER_COLOR]}"

  [[ -n "$SAVED_SECONDARY_COLOR" ]] \
    && SECONDARY_COLOR="${STRING_COLORS[$SAVED_SECONDARY_COLOR]}"
fi

# If color user sets is invalid, print available colors
function INVALID_COLOR {
  printf "${ERROR_}[Error]:${FIM} Invalid color \"%s\"! Available colors: %s\n" "$2" \
      "$(printf "%s\n" "${!STRING_COLORS[@]}" \
      | sort | while read -r c; do printf "%s, " "$c"; done \
      | sed 's/, $//')"
}

# Attributing banner color option flag (temporary)
if [[ "$1" == "-bc" ]] || [[ "$1" == "--banner-color" ]]; then
  if [[ -n "${STRING_COLORS[$2]}" ]]; then
    BANNER_COLOR="${STRING_COLORS[$2]}"
  else
    INVALID_COLOR
    exit 1
  fi
fi

# Attributing set banner color option flag (permanent)
if [[ "$1" == "-sbc" ]] || [[ "$1" == "--set-banner-color" ]]; then
  if [[ -n "${STRING_COLORS[$2]}" ]]; then
    mkdir -p "$(dirname "$CONFIG_COLOR_FILE")"

    TMP_FILE="${CONFIG_COLOR_FILE}.tmp"
    found=0

    [[ -f "$CONFIG_COLOR_FILE" ]] || : > "$CONFIG_COLOR_FILE"

    while IFS= read -r line; do
      case "$line" in
        "[banner-color]"*)
          printf '[banner-color] %s\n' "$2" >> "$TMP_FILE"
          found=1
          ;;
        *)
          printf '%s\n' "$line" >> "$TMP_FILE"
          ;;
      esac
    done < "$CONFIG_COLOR_FILE"

    [[ $found -eq 0 ]] \
      && printf '[banner-color] %s\n' "$2" >> "$TMP_FILE"

    mv "$TMP_FILE" "$CONFIG_COLOR_FILE"

    BANNER_COLOR="${STRING_COLORS[$2]}"
  else
    printf "${ERROR_}[Error]:${FIM} Invalid color \"$2\"! Available colors: ${!STRING_COLORS[*]}\n"
    exit 1
  fi
fi

